#include <bits/stdc++.h>
#include <chrono>
using namespace std;
using namespace std::chrono;

// ---------- GRAPH REPRESENTATION: ADJACENCY LIST ----------
class GraphList {
public:
    int V;
    vector<vector<int>> adj;

    GraphList(int V) {
        this->V = V;
        adj.resize(V);
    }

    void addEdge(int u, int v) {
        adj[u].push_back(v);
        adj[v].push_back(u);
    }

    void BFS(int start) {
        vector<bool> visited(V, false);
        queue<int> q;
        visited[start] = true;
        q.push(start);

        while (!q.empty()) {
            int node = q.front();
            q.pop();
            for (int neighbor : adj[node]) {
                if (!visited[neighbor]) {
                    visited[neighbor] = true;
                    q.push(neighbor);
                }
            }
        }
    }

    void DFSUtil(int node, vector<bool>& visited) {
        visited[node] = true;
        for (int neighbor : adj[node])
            if (!visited[neighbor])
                DFSUtil(neighbor, visited);
    }

    void DFS(int start) {
        vector<bool> visited(V, false);
        DFSUtil(start, visited);
    }
};

// ---------- GRAPH REPRESENTATION: COMPRESSED SPARSE ROW (CSR) ----------
class GraphCSR {
public:
    int V;
    vector<int> row_ptr;
    vector<int> col_idx;

    GraphCSR(int V, const vector<pair<int, int>>& edges) {
        this->V = V;
        row_ptr.resize(V + 1, 0);
        for (auto& e : edges)
            row_ptr[e.first + 1]++;

        for (int i = 1; i <= V; ++i)
            row_ptr[i] += row_ptr[i - 1];

        col_idx.resize(edges.size() * 2);
        vector<int> temp = row_ptr;
        for (auto& e : edges) {
            col_idx[temp[e.first]++] = e.second;
            col_idx[temp[e.second]++] = e.first;
        }
    }

    void BFS(int start) {
        vector<bool> visited(V, false);
        queue<int> q;
        visited[start] = true;
        q.push(start);

        while (!q.empty()) {
            int node = q.front();
            q.pop();
            for (int i = row_ptr[node]; i < row_ptr[node + 1]; ++i) {
                int neighbor = col_idx[i];
                if (!visited[neighbor]) {
                    visited[neighbor] = true;
                    q.push(neighbor);
                }
            }
        }
    }

    void DFSUtil(int node, vector<bool>& visited) {
        visited[node] = true;
        for (int i = row_ptr[node]; i < row_ptr[node + 1]; ++i) {
            int neighbor = col_idx[i];
            if (!visited[neighbor])
                DFSUtil(neighbor, visited);
        }
    }

    void DFS(int start) {
        vector<bool> visited(V, false);
        DFSUtil(start, visited);
    }
};

// ---------- PERFORMANCE MEASUREMENT ----------
template <typename F>
double measure(F func) {
    auto start = high_resolution_clock::now();
    func();
    auto end = high_resolution_clock::now();
    return duration<double, milli>(end - start).count();
}

// ---------- MAIN TEST ----------
int main() {
    srand(time(0));

    vector<int> sizes = {1000, 5000, 10000};

    cout << "\nComparative Analysis of BFS and DFS\n";
    cout << "Vertices\tBFS(List)\tDFS(List)\tBFS(CSR)\tDFS(CSR)\n";

    for (int V : sizes) {
        vector<pair<int, int>> edges;
        for (int i = 0; i < V * 3; ++i) {
            int u = rand() % V;
            int v = rand() % V;
            if (u != v)
                edges.push_back({u, v});
        }

        GraphList g1(V);
        for (auto& e : edges)
            g1.addEdge(e.first, e.second);

        GraphCSR g2(V, edges);

        double bfs_list = measure([&]() { g1.BFS(0); });
        double dfs_list = measure([&]() { g1.DFS(0); });
        double bfs_csr = measure([&]() { g2.BFS(0); });
        double dfs_csr = measure([&]() { g2.DFS(0); });

        cout << V << "\t\t" << bfs_list << "\t\t" << dfs_list
             << "\t\t" << bfs_csr << "\t\t" << dfs_csr << endl;
    }

    return 0;
}


